<UserControl x:Class="AsyncToolWindowSample.ToolWindows.SampleToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AsyncToolWindowSample.ToolWindows"
             mc:Ignorable="d"
             d:DesignHeight="2400"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Width="220"
                    Margin="0,12,0,12">

            <!-- Original -->
            <Button Content="Show VS Location"
                    Click="Button_ShowVsLocation_Click"
                    Width="200" Height="32" Margin="0,0,0,8" />

            <!-- ── Output Window ─────────────────────────────────────── -->
            <TextBlock Text="── Output Window ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Write to Output"     Click="Button_WriteOutput_Click"  Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Clear Output Pane"   Click="Button_ClearOutput_Click"  Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── Status Bar ────────────────────────────────────────── -->
            <TextBlock Text="── Status Bar ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Set Status Text"     Click="Button_SetStatus_Click"    Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Animate (3 s)"        Click="Button_Animate_Click"      Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Show Progress Bar"   Click="Button_Progress_Click"     Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── Selection (DTE) ───────────────────────────────────── -->
            <TextBlock Text="── Selection (DTE / Tier 1) ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Show Caret Info (DTE)"      Click="Button_DteCaretInfo_Click"  Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Select Current Line (DTE)"  Click="Button_DteSelectLine_Click" Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Find 'TODO' (DTE)"          Click="Button_DteFindTodo_Click"   Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Collapse Selection (DTE)"   Click="Button_DteCollapse_Click"   Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── Selection (MEF) ───────────────────────────────────── -->
            <TextBlock Text="── Selection (MEF / Tier 2) ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Show Caret Info (MEF)"      Click="Button_MefCaretInfo_Click"      Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Show Selected Spans (MEF)"  Click="Button_MefSelectedSpans_Click"  Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Insert Text at Caret (MEF)" Click="Button_MefInsert_Click"         Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Replace Selection (MEF)"    Click="Button_MefReplace_Click"        Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Buffer Char Count (MEF)"    Click="Button_MefBufferCount_Click"    Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── Document &amp; File APIs ──────────────────────────── -->
            <TextBlock Text="── Document &amp; File APIs ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Show Active Doc Info"   Click="Button_DocInfo_Click"      Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="List All Open Docs"     Click="Button_DocListAll_Click"   Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="TextDoc Info + Preview" Click="Button_TextDocInfo_Click"  Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Read Lines 1–5"         Click="Button_DocReadLines_Click" Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Save Active Document"   Click="Button_DocSave_Click"      Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Format Document"        Click="Button_DocFormat_Click"    Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Save All"               Click="Button_DocSaveAll_Click"   Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Go To Line 1"           Click="Button_DocGoToLine_Click"  Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── §5 Project &amp; Solution ─────────────────────────── -->
            <TextBlock Text="── Project &amp; Solution APIs ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Show Solution Info"       Click="Button_SolInfo_Click"       Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="List All Projects"        Click="Button_ProjList_Click"       Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Active Doc Project Info"  Click="Button_ProjActiveDoc_Click"  Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="List References"          Click="Button_ProjRefs_Click"       Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="List Project Files"       Click="Button_ProjFiles_Click"      Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Active Build Config"      Click="Button_ProjConfig_Click"     Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Build Solution"           Click="Button_SolBuild_Click"       Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── §6 Menu &amp; Command ──────────────────────────────── -->
            <TextBlock Text="── Menu &amp; Command (§6) ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Show Dynamic Cmd State"   Click="Button_MenuCmdState_Click"   Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Fire Toggle Command"      Click="Button_MenuToggle_Click"     Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Fire DocAction Command"   Click="Button_MenuDocAction_Click"  Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Fire ContextInfo Command" Click="Button_MenuContextInfo_Click" Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Exec VS Cmd: FormatDoc"   Click="Button_MenuVsCmd_Click"      Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── §7 Toolbar &amp; CommandBar ───────────────────────── -->
            <TextBlock Text="── Toolbar &amp; CommandBar (§7) ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="List All CommandBars"     Click="Button_BarList_Click"        Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Show 'Standard' Bar Info" Click="Button_BarStandard_Click"    Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Create Custom Toolbar"    Click="Button_BarCreate_Click"      Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Show Custom Toolbar"      Click="Button_BarShow_Click"        Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Hide Custom Toolbar"      Click="Button_BarHide_Click"        Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Delete Custom Toolbar"    Click="Button_BarDelete_Click"      Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Custom Toolbar Status"    Click="Button_BarStatus_Click"      Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── §9 DTE Events ─────────────────────────────────────── -->
            <TextBlock Text="── DTE Events (§9) ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Subscribe to Events"      Click="Button_EventSubscribe_Click"   Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Unsubscribe from Events"  Click="Button_EventUnsubscribe_Click" Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Show Event Status"        Click="Button_EventStatus_Click"      Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── §10 Settings / Options ─────────────────────────────── -->
            <TextBlock Text="── Settings / Options (§10) ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="Show Current Options"     Click="Button_OptShow_Click"   Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Open Options Dialog"      Click="Button_OptOpen_Click"   Width="200" Height="32" Margin="0,0,0,6" />

            <!-- ── §12 Text Adornment / Tagger ───────────────────────── -->
            <TextBlock Text="── Text Adornment / Tagger (§12) ──" HorizontalAlignment="Center"
                       Margin="0,8,0,4" Foreground="Gray" FontSize="11"/>
            <Button Content="TODO Tagger: Active?"     Click="Button_TaggerStatus_Click" Width="200" Height="32" Margin="0,0,0,6" />
            <Button Content="Count TODOs in Buffer"    Click="Button_TaggerCount_Click"  Width="200" Height="32" Margin="0,0,0,6" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
